# PrivaDEX Frontend — Environment Variables
# Vite uses VITE_ prefix instead of NEXT_PUBLIC_

# ─── Network ──────────────────────────────────────────────────────────────────
VITE_RPC_URL=https://api.explorer.provable.com/v1
VITE_NETWORK=testnet

# ─── Program IDs ──────────────────────────────────────────────────────────────
VITE_PROGRAM_TOKEN=privadex_token_v2.aleo
VITE_PROGRAM_AMM=privadex_amm_v10.aleo
VITE_PROGRAM_AMM_BTCX=privadex_amm_btcx_v6.aleo
VITE_PROGRAM_AMM_ETHX=privadex_amm_ethx_v6.aleo
VITE_PROGRAM_AMM_NATIVE_BTCX=privadex_amm_native_btcx_v7.aleo
VITE_PROGRAM_AMM_NATIVE_ETHX=privadex_amm_native_ethx_v7.aleo
VITE_PROGRAM_AMM_BTCX_ETHX=privadex_amm_btcx_ethx_v6.aleo
VITE_PROGRAM_USDCX=test_usdcx_stablecoin.aleo
VITE_PROGRAM_TOKEN_REGISTRY=token_registry.aleo
VITE_PROGRAM_DARKPOOL=privadex_darkpool_v4.aleo
VITE_PROGRAM_ORDERBOOK=privadex_orderbook_v4.aleo
VITE_PROGRAM_ROUTER=privadex_router_v2.aleo

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_USE_ONCHAIN=true

# ─── Record Scanner (Provable RSS — reliable record discovery) ────────────────
# Get credentials at https://developer.aleo.org/sdk/record-scanning/
# Leave empty to disable scanner (Shield Wallet only)
VITE_SCANNER_URL=https://api.provable.com/scanner
VITE_SCANNER_API_KEY=
VITE_SCANNER_CONSUMER_ID=

# ─── Faucet Admin Key (testnet only — signs mint transactions for BTCx/ETHx) ──
VITE_FAUCET_PRIVATE_KEY=APrivateKey1zkp3PXm3fMSgNM9kmS6M2MQP73Ca8M52o4SxRNVYSKh4eyd
VITE_FAUCET_ADDRESS=aleo1m27r03ay4y7aqqzcdu58aggcw6aefc6vuyz0jtp53834ycdl35yqhy8j88
